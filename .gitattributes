# Enforce consistent line endings across platforms
* text=auto

# Source and docs use LF
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini  text eol=lf
*.cfg  text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf

# Windows-native scripts use CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf
